{
	"name": "todo-v2",
	"version": "1.14.3",
	"main": "expo-router/entry",
	"author": {
		"email": "cfmorales.diaz@gmail.com",
		"name": "Cristian Morales",
		"url": "https://github.com/Cristian-F-M"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Cristian-F-M/todo-app-v2.git"
	},
	"private": false,
	"keywords": [
		"todo",
		"CM",
		"lista de tareas",
		"tareas",
		"tasks",
		"folders",
		"themes",
		"temas",
		"personalización",
		"theme-creation"
	],
	"description": "Android application made with react-native + expo, which allows the user to create tasks, organize them into folders, mark them as completed, allows changing themes, creation of automatic and manual themes 100% customizable.",
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"enabled": true,
				"exclude": [
					"react-native-modalize",
					"react-native-uuid",
					"tailwindcss",
					"react-native-bouncy-checkbox"
				],
				"listUnknownPackages": true
			}
		}
	},
	"scripts": {
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"lint": "eslint ."
	},
	"dependencies": {
		"@animatereactnative/marquee": "0.5.2",
		"@react-native-async-storage/async-storage": "2.2.0",
